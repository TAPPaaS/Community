{
  "description": "Philips Hue bridge — policy-only module for firewall rules (no VM)",
  "version": "0.1.0",
  "releaseDate": "2026-05-23",
  "maintainer": "@ErikDaniel007",
  "status": "Development",
  "location": "/home/tappaas/Community/src/ErikDaniel007/home-automation/hue",
  "vmname": "hue",
  "vmtag": "TAPPaaS,Community,HomeAutomation,Hardware",
  "zone0": "iot-local",
  "aliasType": "host",
  "firewallType": "opnsense",
  "ports": [
    {
      "port": 80,
      "protocol": "TCP",
      "description": "Hue bridge HTTP API"
    },
    {
      "port": 443,
      "protocol": "TCP",
      "description": "Hue bridge HTTPS API"
    }
  ],
  "discoveryMdns": ["home", "srv-home"],
  "provides": [
    "bridge"
  ],
  "dependsOn": [
    "firewall:rules",
    "firewall:discovery"
  ],
  "_comment_direct_access": "No-HA scenario: add egress iot-local ports 80/443 to sysap.json + hue:bridge in sysap.dependsOn. See INSTALL.md advanced section. Not recommended: breaks zone isolation."
}
